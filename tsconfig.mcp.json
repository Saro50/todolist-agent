{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["es2022"],
    "outDir": "./dist/mcp",
    "rootDir": "./mcp",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["mcp/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
