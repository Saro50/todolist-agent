    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "mcp": "MCP_API_PORT=4000 ts-node -P tsconfig.mcp.json mcp/index.ts",
    "mcp:http": "MCP_API_PORT=4000 MCP_PORT=4001 ts-node --esm mcp/index-http.ts"
  },
  "bin": {
    "kanai-mcp": "./dist/mcp/index.js"
  },
